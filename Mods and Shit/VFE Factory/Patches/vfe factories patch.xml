<!-- ODYSSEY -->

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Odyssey</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>

        <li Class="PatchOperationAdd">
          <success>Always</success>
          <xpath>/Defs</xpath>
          <value>
            <ResearchProjectDef>
                <defName>Ferny_AutomatedFishfarm</defName>
                <label>Automated fishfarm</label>
                <description>Build an industrial fish breeding and harvesting facility designed to automatically extract fish from bodies of water with fish populations.</description>
                <baseCost>2500</baseCost>
                <techLevel>Industrial</techLevel>
                <researchViewX>3.50</researchViewX>
                <researchViewY>0.50</researchViewY>
                <tab>VanillaExpanded</tab>
                <prerequisites>
                    <li>Fabrication</li>
                </prerequisites>
            </ResearchProjectDef>
          </value>
        </li>

        <li Class="PatchOperationReplace">
          <success>Always</success>
          <xpath>Defs/ThingDef[defName="VFEFactory_AutomatedFishfarm"]/researchPrerequisites</xpath>
        <value>
            <researchPrerequisites>
            <li>Ferny_AutomatedFishfarm</li>
            </researchPrerequisites>
        </value>
        </li>
      </operations>
    </match>
  </Operation>

<!-- VE COOKING -->
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Vanilla Cooking Expanded</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>

        <li Class="PatchOperationAdd">
          <success>Always</success>
          <xpath>/Defs</xpath>
          <value>
            <ResearchProjectDef>
                <defName>Ferny_AutomatedCannery</defName>
                <label>Automated cannery</label>
                <description>Build an automated industrial preserving system for the mass production of canned goods from various raw ingredients, requiring no manual labor.</description>
                <baseCost>1800</baseCost>
                <techLevel>Industrial</techLevel>
                <researchViewX>3.50</researchViewX>
                <researchViewY>1.00</researchViewY>
                <tab>VanillaExpanded</tab>
                <prerequisites>
                    <li>Fabrication</li>
                </prerequisites>
            </ResearchProjectDef>
          </value>
        </li>

        <li Class="PatchOperationReplace">
          <success>Always</success>
          <xpath>Defs/ThingDef[defName="VFEFactory_AutomatedCannery"]/researchPrerequisites</xpath>
        <value>
            <researchPrerequisites>
            <li>Ferny_AutomatedCannery</li>
            </researchPrerequisites>
        </value>
        </li>
      </operations>
    </match>
  </Operation>



